# YouTube Sleep Queue Configuration
# Copy this file to .env and configure your settings

# Target playlist ID (optional - will create new playlist if not specified)
# To find your playlist ID: go to YouTube playlist -> look at URL
# Example: https://www.youtube.com/playlist?list=PLrAXtmRdnEQy4QxTaQn2wJWCNYiV4_Ap1
# The playlist ID is: PLrAXtmRdnEQy4QxTaQn2wJWCNYiV4_Ap1
PLAYLIST_ID=

# Playlist settings (used when creating new playlists)
PLAYLIST_NAME=YouTube Sleep Queue
PLAYLIST_VISIBILITY=unlisted

# Video filtering settings
VIDEO_MIN_DURATION_SECONDS=120
VIDEO_MAX_DURATION_SECONDS=
LOOKBACK_HOURS=168
DATE_FILTER_MODE=lookback
# DATE_FILTER_DAYS=7
# DATE_FILTER_START=2026-01-01
# DATE_FILTER_END=2026-01-31
MAX_VIDEOS_TO_FETCH=50

# Skip livestreams and premieres (true/false)
SKIP_LIVE_CONTENT=true

# Channel filtering (optional)
# Comma-separated list of channel IDs to include (leave empty to include all)
# To find channel ID: go to channel -> About tab -> copy channel ID
# Example: UC1234567890,UC0987654321
CHANNEL_ID_WHITELIST=
# Preferred channel filter variables (YouTube channel IDs are UC + 22 characters)
CHANNEL_FILTER_MODE=none
CHANNEL_ALLOWLIST=
CHANNEL_BLOCKLIST=

# Keyword filters: none, include, exclude, or both
KEYWORD_FILTER_MODE=none
KEYWORD_INCLUDE=
KEYWORD_EXCLUDE=
KEYWORD_MATCH_TYPE=any
KEYWORD_CASE_SENSITIVE=false
KEYWORD_SEARCH_DESCRIPTION=false

# Ollama ranking (local by default). Metadata is sent to this configured endpoint.
# Only use an endpoint you trust.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=30
OLLAMA_CONCURRENCY=1
SLEEP_MINIMUM_SCORE=70
SLEEP_QUEUE_SIZE=10

# Optional dashboard refresh timeout; otherwise derived from max videos and Ollama timeout
REFRESH_TIMEOUT_SECONDS=
